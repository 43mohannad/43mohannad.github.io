<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>منصة العقارات - 43mohannad</title>

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Google Font Arabic -->
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">

<style>
body {
    font-family: 'Cairo', sans-serif;
    background-color: #f4f6f9;
}
header {
    background: #0f4c81;
    color: white;
    padding: 40px 0;
    text-align: center;
}
header h1 {
    font-weight: 700;
    margin-bottom: 10px;
}
nav {
    background: #083358;
}
nav a {
    color: white !important;
    margin: 0 15px;
    font-weight: 600;
}
.hero {
    background: url('https://images.unsplash.com/photo-1580584125857-d392178788b7?auto=format&fit=crop&w=1470&q=80') center/cover no-repeat;
    height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-shadow: 1px 1px 5px rgba(0,0,0,0.6);
    margin-bottom: 30px;
}
.form-box, .search-box {
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 3px 15px rgba(0,0,0,0.1);
    margin-bottom: 30px;
}
input, select {
    margin-bottom: 15px;
}
button {
    background: #0f4c81;
    color: white;
    border: none;
}
button:hover {
    background: #1666ad;
}
.card img {
    height: 180px;
    object-fit: cover;
}
footer {
    background: #111;
    color: white;
    padding: 20px;
    text-align: center;
    margin-top: 40px;
}
</style>
</head>
<body>

<header>
    <h1>منصة العقارات</h1>
    <p>بيع | شراء | تأجير</p>
</header>

<nav class="navbar navbar-expand-lg">
  <div class="container justify-content-center">
    <a class="nav-link" href="#">الرئيسية</a>
    <a class="nav-link" href="#">العقارات</a>
    <a class="nav-link" href="#">إضافة عقار</a>
  </div>
</nav>

<div class="container">

<div class="hero">
    <h2>ابحث عن عقارك المثالي اليوم</h2>
</div>

<div class="form-box">
<h3>إضافة عقار جديد</h3>
<input id="title" class="form-control" placeholder="اسم العقار">
<input id="location" class="form-control" placeholder="الموقع">
<select id="type" class="form-select">
<option>شقة</option>
<option>فيلا</option>
<option>أرض</option>
<option>مكتب</option>
</select>
<input id="price" class="form-control" placeholder="السعر">
<input id="image" class="form-control" placeholder="رابط صورة">
<button class="btn w-100" onclick="addProperty()">إضافة العقار</button>
</div>

<div class="search-box">
<h3>البحث</h3>
<input id="search" class="form-control" placeholder="ابحث عن موقع أو عقار">
<select id="filterType" class="form-select">
<option value="">كل الأنواع</option>
<option>شقة</option>
<option>فيلا</option>
<option>أرض</option>
<option>مكتب</option>
</select>
<button class="btn w-100" onclick="searchProperty()">بحث</button>
</div>

<h3 class="mb-3">العقارات المتاحة</h3>
<div class="row" id="properties"></div>

</div>

<footer>
© جميع الحقوق محفوظة - 43mohannad
</footer>

<script>
let properties = JSON.parse(localStorage.getItem("properties")) || [];

function displayProperties(list = properties){
    let container = document.getElementById("properties");
    container.innerHTML = "";
    list.forEach(p => {
        container.innerHTML += `
        <div class="col-md-4 mb-4">
            <div class="card">
                <img src="${p.image}" class="card-img-top" alt="${p.title}">
                <div class="card-body">
                    <h5 class="card-title">${p.title}</h5>
                    <p class="card-text">${p.location}</p>
                    <p class="text-muted">${p.type}</p>
                    <p class="text-success fw-bold">${p.price}</p>
                    <button class="btn btn-primary w-100" onclick="contact()">تواصل</button>
                </div>
            </div>
        </div>`;
    });
}

function addProperty(){
    let property = {
        title: document.getElementById("title").value,
        location: document.getElementById("location").value,
        type: document.getElementById("type").value,
        price: document.getElementById("price").value,
        image: document.getElementById("image").value
    };
    properties.push(property);
    localStorage.setItem("properties", JSON.stringify(properties));
    displayProperties();
}

function searchProperty(){
    let text = document.getElementById("search").value.toLowerCase();
    let type = document.getElementById("filterType").value;
    let filtered = properties.filter(p => 
        (p.title.toLowerCase().includes(text) || p.location.toLowerCase().includes(text)) &&
        (type=="" || p.type==type)
    );
    displayProperties(filtered);
}

function contact(){
    window.open("https://wa.me/966XXXXXXXXX", "_blank"); // ضع رقم واتسابك هنا
}

displayProperties();
</script>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
